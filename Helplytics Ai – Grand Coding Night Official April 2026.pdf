<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HelpHub AI - Create Request</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="../css/global.css">
    <link rel="stylesheet" href="../css/navbar.css">
    <link rel="stylesheet" href="../css/create-request.css">
</head>
<body class="create-request-page">

    <div class="background-mesh"></div>

    <header class="navbar create-navbar">
        <a href="../index.html" class="logo-area" style="text-decoration: none; color: inherit;">
            <div class="logo-icon">H</div>
            <span class="logo-text">HelpHub AI</span>
        </a>
        
        <nav class="nav-links">
            <a href="dashboard.html">Dashboard</a>
            <a href="explore.html">Explore</a>
            <a href="create-request.html" class="active">Create Request</a>
        </nav>
    </header>

    <main class="container create-request-container">
        
        <!-- Header Card -->
        <section class="create-header-card">
            <div class="create-pre-heading">CREATE REQUEST</div>
            <h1 class="create-header-heading">Turn a rough problem into a clear help request.</h1>
            <p class="create-header-subtitle">Use built-in AI suggestions for category, urgency, tags, and a stronger description rewrite.</p>
        </section>

        <!-- Layout Grid -->
        <div class="create-layout">
            
            <!-- Left Panel: Form -->
            <section class="create-panel">
                <form class="create-form" action="#" method="POST">
                    
                    <div class="form-group">
                        <label for="req-title">Title</label>
                        <input type="text" id="req-title" class="form-control" value="Need review on my JavaScript quiz app before submission">
                    </div>

                    <div class="form-group">
                        <label for="req-desc">Description</label>
                        <textarea id="req-desc" class="form-control">Explain the challenge, your current progress, deadline, and what kind of help would be useful.</textarea>
                    </div>

                    <div class="form-group-row">
                        <div class="form-group">
                            <label for="req-tags">Tags</label>
                            <input type="text" id="req-tags" class="form-control" value="JavaScript, Debugging, Review">
                        </div>
                        <div class="form-group">
                            <label for="req-category">Category</label>
                            <select id="req-category" class="form-control form-select">
                                <option>Web Development</option>
                                <option>Design</option>
                                <option>Career</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="req-urgency">Urgency</label>
                        <select id="req-urgency" class="form-control form-select">
                            <option>High</option>
                            <option>Medium</option>
                            <option>Low</option>
                        </select>
                    </div>

                    <div class="form-actions">
                        <button type="button" class="btn-secondary-pill">Apply AI suggestions</button>
                        <button type="button" class="btn-primary-pill">Publish request</button>
                    </div>

                </form>
            </section>

            <!-- Right Panel: AI Assistant -->
            <section class="create-panel">
                <div class="ai-panel-pre-heading">AI ASSISTANT</div>
                <h2 class="ai-panel-heading">Smart request guidance</h2>

                <div class="ai-insights-list">
                    
                    <div class="ai-insight-item">
                        <div class="ai-insight-label">Suggested category</div>
                        <div class="ai-insight-value text-right">Community</div>
                    </div>

                    <div class="ai-insight-item">
                        <div class="ai-insight-label">Detected urgency</div>
                        <div class="ai-insight-value text-right">Low</div>
                    </div>

                    <div class="ai-insight-item">
                        <div class="ai-insight-label">Suggested tags</div>
                        <div class="ai-insight-value text-left">Add more detail for smarter tags</div>
                    </div>

                    <div class="ai-insight-item">
                        <div class="ai-insight-label">Rewrite suggestion</div>
                        <div class="ai-insight-value text-left">Start describing the challenge to generate a stronger version.</div>
                    </div>

                </div>
            </section>

        </div>

    </main>

</body>
</html>
